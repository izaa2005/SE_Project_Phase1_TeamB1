# Backend Environment Variables
# Copy this to .env and fill in with your actual values

# Database
# Local development default (works out of the box)
DATABASE_URL=sqlite:///database/internlink.db

# MySQL example (uncomment and replace with real credentials)
# DATABASE_URL=mysql+pymysql://<username>:<password>@localhost:3306/internlink_db

# JWT
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production

# Email Configuration (for sending verification emails)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@internlink.com

# Optional: Flask environment
FLASK_ENV=development
FLASK_DEBUG=1

# Optional: API base URL (for email verification links)
API_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000
